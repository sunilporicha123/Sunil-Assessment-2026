# Copy to terraform.tfvars and fill in real values. Never commit terraform.tfvars.

aws_region   = "us-east-1"
environment  = "dev"
cluster_name = "datawave-federation-eks"

rds_postgres_endpoint = "datawave-db1-postgres.xxxxxxx.us-east-1.rds.amazonaws.com:5432"
rds_postgres_sg_id    = "sg-0123456789abcdef0"

rds_mysql_endpoint = "datawave-db2-mysql.xxxxxxx.us-east-1.rds.amazonaws.com:3306"
rds_mysql_sg_id    = "sg-0fedcba9876543210"

secrets_manager_db_secret_arn_postgres = "arn:aws:secretsmanager:us-east-1:123456789012:secret:datawave/rds/postgres-AbCdEf"
secrets_manager_db_secret_arn_mysql    = "arn:aws:secretsmanager:us-east-1:123456789012:secret:datawave/rds/mysql-GhIjKl"

allowed_admin_cidrs = ["203.0.113.0/24"]
